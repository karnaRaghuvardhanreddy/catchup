<h2>Friends</h2>

<h3>Pending Requests</h3>
<% if @pending_requests.present? %>
  <% @pending_requests.each do |request| %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="card-text"><%= request.user.email %> wants to be friends.</p>
        <button class="btn btn-success accept-friend-btn" data-friendship-id="<%= request.id %>">Accept</button>
        <button class="btn btn-danger reject-friend-btn" data-friendship-id="<%= request.id %>">Reject</button>
      </div>
    </div>
  <% end %>
<% else %>
  <p>No pending friend requests.</p>
<% end %>

<h3>Suggested Users</h3>
<% if @suggested_users.present? %>
  <% @suggested_users.each do |user| %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="card-text"><%= user.email %></p>

       <% if current_user.friends.include?(user) %>
  <button class="btn btn-success disabled">Friends</button>
<% elsif current_user.pending_requests.any? { |request| request.friend == user } %>
  <button class="btn btn-secondary disabled">Request Sent</button>
<% else %>
  <%= button_tag "Add Friend", class: "btn btn-primary add-friend-btn", data: { user_id: user.id } %>
<% end %>

      </div>
    </div>
  <% end %>
<% else %>
  <p>No suggested users available.</p>
<% end %>

<h3>Search Users</h3>
<%= form_with url: friendships_path, method: :get, local: true do %>
  <div class="input-group mb-3">
    <%= text_field_tag :query, params[:query], class: "form-control", placeholder: "Search for users..." %>
    <button type="submit" class="btn btn-secondary">Search</button>
  </div>
<% end %>

<script>
 document.addEventListener("DOMContentLoaded", function () {
  document.querySelectorAll(".add-friend-btn").forEach((button) => {
    const status = button.dataset.status;  // Use the status (e.g., 'friend', 'pending')

    // Disable the button if the user is already a friend or has a pending request
    if (status === 'friend' || status === 'pending') {
      button.classList.add("disabled");
      button.setAttribute("disabled", "disabled");
      button.innerHTML = "Request Sent";
    }

    button.addEventListener("click", function () {
      const userId = button.dataset.userId;

      fetch("/friendships", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").content,
        },
        body: JSON.stringify({ user_id: userId })
      })
      .then((response) => {
        if (!response.ok) {
          throw new Error(`HTTP error! Status: ${response.status}`);
        }
        return response.json();
      })
      .then((data) => {
        if (data.status === "success") {
          button.innerHTML = "Request Sent";
          button.classList.remove("btn-primary");
          button.classList.add("btn-secondary", "disabled");
          button.setAttribute("disabled", "disabled");
        } else {
          alert("Failed to send request: " + data.message);
        }
      })
      .catch((error) => console.error("Error:", error));
    });
  });
});

</script>
