<!DOCTYPE html>
<html>
<head>
  <title>Simple Facebook App</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" %>
  <meta name="csrf-token" content="<%= csrf_meta_tags %>"/>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <%= link_to "Simple Facebook", user_signed_in? ? authenticated_root_path : unauthenticated_root_path, class: "navbar-brand" %>
      <% if user_signed_in? %>
        <ul class="navbar-nav">
          <li class="nav-item"><%= link_to "Home", thoughts_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Friends", friendships_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Account", profile_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Logout", destroy_user_session_path, method: :delete, class: "nav-link", data: { turbo: false } %></li>
        </ul>
      <% end %>
    </div>
  </nav>
  <div class="container mt-4">
    <%= yield %>
  </div>
</body>
</html>